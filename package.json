{
  "name": "pico",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc -p packages/core && tsc -p packages/web-protocol && tsc -p apps/engine && tsc -p apps/web && tsc -p .",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "lint:comments": "bun run scripts/lint-comments.ts --all",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun run lint:comments && bun test",
    "prepare": "lefthook install && effect-tsgo patch"
  },
  "dependencies": {
    "starlight-theme-next": "^0.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@effect/tsgo": "^0.24.2",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "typescript": "7.0.2"
  }
}
