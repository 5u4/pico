#!/usr/bin/env bash
# Mirror this repo's local gitignored ambient files (the script's `LINK` list) into a
# newly created git worktree — see scripts/link-worktree-ambient.sh. cwd here is
# the new worktree, whose checkout may predate the script (an old fork ref), so
# resolve the script from the main worktree instead, and no-op when it's absent:
# a failing post-checkout must never break `git worktree add`.
main="$(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{sub(/^worktree /, ""); print; exit}')"
script="$main/scripts/link-worktree-ambient.sh"
[ -n "$main" ] && [ -x "$script" ] && exec "$script" "$@"
exit 0
